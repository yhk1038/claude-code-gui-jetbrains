#!/usr/bin/env bash
# ccg — claude-code-gui terminal launcher.
#
# Usage: ccg [run | list | update | stop | version | doctor | self-update | uninstall | help]
#
# This is the entry point only: resolve paths, source lib/* + commands/* in
# dependency order, then dispatch. All logic lives in those modules. Sourcing
# this file (bats) loads every cmd_* without dispatching (BASH_SOURCE != $0).

set -euo pipefail

# ─── path resolution ─────────────────────────────────────────

# Resolve the directory of this script even if invoked via symlink.
_ccg_self_dir() {
  local src=${BASH_SOURCE[0]}
  while [[ -L "$src" ]]; do
    local dir
    dir=$(cd -P "$(dirname "$src")" && pwd)
    src=$(readlink "$src")
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -P "$(dirname "$src")" && pwd
}

CCG_SELF_DIR=$(_ccg_self_dir)
# Installation layout: <root>/bin/ccg, <root>/lib/, <root>/commands/, <root>/locales/
CCG_ROOT=$(cd "$CCG_SELF_DIR/.." && pwd)
CCG_LIB_DIR="$CCG_ROOT/lib"
CCG_COMMANDS_DIR="$CCG_ROOT/commands"
CCG_LOCALES_DIR="$CCG_ROOT/locales"
export CCG_LOCALES_DIR

# Load library modules in dependency order. Folder modules expose their public
# API through an index.sh barrel that sources its own siblings.
# shellcheck source=../lib/i18n/index.sh
source "$CCG_LIB_DIR/i18n/index.sh"
# shellcheck source=../lib/version.sh
source "$CCG_LIB_DIR/version.sh"
# shellcheck source=../lib/port/index.sh
source "$CCG_LIB_DIR/port/index.sh"
# shellcheck source=../lib/proc/index.sh
source "$CCG_LIB_DIR/proc/index.sh"
# shellcheck source=../lib/backend-detect/index.sh
source "$CCG_LIB_DIR/backend-detect/index.sh"
# shellcheck source=../lib/browser.sh
source "$CCG_LIB_DIR/browser.sh"
# shellcheck source=../lib/runtime.sh
source "$CCG_LIB_DIR/runtime.sh"
# shellcheck source=../lib/spawn/index.sh
source "$CCG_LIB_DIR/spawn/index.sh"

# Load command modules. Single-file commands define cmd_<name>; folder commands
# (run/list/stop) expose cmd_<name> through their index.sh barrel.
# shellcheck disable=SC1090
for _cmd_module in \
  run/index.sh list/index.sh stop/index.sh \
  doctor.sh version.sh update.sh self-update.sh uninstall.sh help.sh; do
  source "$CCG_COMMANDS_DIR/$_cmd_module"
done
unset _cmd_module

# Load locale
load_locale "$(detect_locale)"

# ─── main dispatcher ─────────────────────────────────────────

ccg_main() {
  local cmd=${1:-run}
  shift || true

  case "$cmd" in
    run)           cmd_run "$@" ;;
    list)          cmd_list "$@" ;;
    update)        cmd_update "$@" ;;
    stop)          cmd_stop "$@" ;;
    version|--version) cmd_version "$@" ;;
    doctor)        cmd_doctor "$@" ;;
    self-update)   cmd_self_update "$@" ;;
    uninstall)     cmd_uninstall "$@" ;;
    help|--help|-h) cmd_help "$@" ;;
    *)
      printf '%s\n' "$(t unknown_command "$cmd")" >&2
      cmd_help >&2
      return 1
      ;;
  esac
}

# Dispatch only when executed directly (not when sourced for testing).
# `source ccg` from bats sets BASH_SOURCE[0] != $0.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  ccg_main "$@"
fi
