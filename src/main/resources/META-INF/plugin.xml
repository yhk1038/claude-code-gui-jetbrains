<idea-plugin>
    <id>com.github.yhk1038.claude-code-gui</id>
    <name>Claude Code GUI</name>
    <vendor email="yhk1038@github.com" url="https://github.com/yhk1038">yhk1038</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>
    <depends optional="true" config-file="claudecode-jcef.xml">com.intellij.modules.jcef</depends>

    <resource-bundle>messages.ClaudeCodeBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Sidebar button: opens an editor tab (EDITOR_TAB mode) or hosts chat
             content tabs directly (TOOL_WINDOW mode). canCloseContents enables the
             per-tab close button used in TOOL_WINDOW mode. -->
        <toolWindow
            id="Claude Code"
            anchor="right"
            icon="/icons/claudeCode.svg"
            canCloseContents="true"
            factoryClass="com.github.yhk1038.claudecodegui.toolwindow.ClaudeCodeToolWindowFactory"/>

        <!-- Left sidebar panel that hosts the session list -->
        <toolWindow
            id="Claude Sessions"
            anchor="left"
            icon="/icons/claudeSessions.svg"
            factoryClass="com.github.yhk1038.claudecodegui.toolwindow.ClaudeSessionsToolWindowFactory"/>

        <!-- Editor Tab -->
        <fileEditorProvider
            implementation="com.github.yhk1038.claudecodegui.editor.ClaudeCodeEditorProvider"/>

        <!-- Project service for session management -->
        <projectService
            serviceImplementation="com.github.yhk1038.claudecodegui.services.ClaudeSessionService"/>

        <!-- Application service for Node.js backend process management (singleton per computer) -->
        <applicationService
            serviceImplementation="com.github.yhk1038.claudecodegui.services.NodeBackendService"/>

        <!-- Application service for CLI management -->
        <applicationService
            serviceImplementation="com.github.yhk1038.claudecodegui.services.ClaudeCliService"/>

        <!-- Settings/Preferences -->
        <applicationConfigurable
            parentId="tools"
            instance="com.github.yhk1038.claudecodegui.settings.ClaudeCodeSettingsConfigurable"
            id="com.github.yhk1038.claudecodegui.settings"
            displayName="Claude Code"/>

        <!-- 파일 기반 설정 관리자 -->
        <applicationService
            serviceImplementation="com.github.yhk1038.claudecodegui.settings.SettingsManager"/>

        <!-- Project service for editor tab state persistence -->
        <projectService
            serviceImplementation="com.github.yhk1038.claudecodegui.services.EditorTabStateService"/>

        <!-- Project service hosting chat sessions in the tool window (TOOL_WINDOW mode) -->
        <projectService
            serviceImplementation="com.github.yhk1038.claudecodegui.hosting.ToolWindowHost"/>

        <!-- Project service for JCEF browser pooling (tab move/split preservation) -->
        <projectService
            serviceImplementation="com.github.yhk1038.claudecodegui.services.ClaudeCodeBrowserService"/>

        <!-- Restore persisted chat sessions into the current host on project open -->
        <postStartupActivity
            implementation="com.github.yhk1038.claudecodegui.startup.ChatHostRestoreActivity"/>

        <!-- Register passive auto-selection listeners (tab switch + text selection)
             that push the active file/selection to /internal/ide-selection -->
        <postStartupActivity
            implementation="com.github.yhk1038.claudecodegui.startup.IdeSelectionActivity"/>

        <!-- Keep-alive eager start: spawn the project's backend on project open (no JCEF)
             when the global "Keep backend running" toggle is ON -->
        <postStartupActivity
            implementation="com.github.yhk1038.claudecodegui.startup.BackendKeepAliveActivity"/>

        <!-- WebView resource server -->
        <httpRequestHandler
            implementation="com.github.yhk1038.claudecodegui.toolwindow.WebViewRequestHandler"/>

        <!-- Notification group for JCEF runtime unavailability warning -->
        <notificationGroup
            id="claude-code-gui.jcef-runtime"
            displayType="STICKY_BALLOON"
            displayName="JCEF Runtime"/>

        <!-- Tab icon badge for unread streaming completions -->
        <fileIconPatcher
            implementation="com.github.yhk1038.claudecodegui.editor.ClaudeCodeFileIconPatcher"/>

        <!-- Backend liveness dot + status card in the status bar -->
        <statusBarWidgetFactory
            id="ClaudeCodeGui.BackendStatus"
            implementation="com.github.yhk1038.claudecodegui.statusbar.BackendStatusBarWidgetFactory"/>
    </extensions>

    <!-- Prewarm version-scoped resource extraction at app frame creation (issue #149) -->
    <applicationListeners>
        <listener
            class="com.github.yhk1038.claudecodegui.startup.ResourceExtractionPrewarmActivity"
            topic="com.intellij.ide.AppLifecycleListener"/>
        <!-- Per-project keep-alive clamp: release the keep-alive gate when a project
             window closes so its backend cannot outlive the window forever -->
        <listener
            class="com.github.yhk1038.claudecodegui.startup.BackendProjectCloseListener"
            topic="com.intellij.openapi.project.ProjectCloseListener"/>
    </applicationListeners>

    <!-- Clean up session state only on real tab close (not on tab move/split) -->
    <projectListeners>
        <listener
            class="com.github.yhk1038.claudecodegui.editor.ClaudeCodeEditorManagerListener"
            topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>
    </projectListeners>

    <actions>
        <!-- Action to open Claude Code panel -->
        <action
            id="ClaudeCode.Open"
            class="com.github.yhk1038.claudecodegui.actions.OpenClaudeCodeAction"
            text="Open Claude Code"
            description="Open Claude Code chat panel"
            icon="AllIcons.Actions.Execute">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift C"/>
        </action>

        <!-- New Tab action (only when Claude Code editor is focused) -->
        <action
            id="ClaudeCode.NewTab"
            class="com.github.yhk1038.claudecodegui.actions.NewClaudeCodeTabAction"
            text="New Claude Code Tab"
            description="Open a new Claude Code editor tab">
            <keyboard-shortcut keymap="$default" first-keystroke="meta N"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl N"/>
        </action>

        <!-- Open Settings action (only when Claude Code editor is focused) -->
        <action
            id="ClaudeCode.OpenSettings"
            class="com.github.yhk1038.claudecodegui.actions.OpenClaudeCodeSettingsAction"
            text="Open Claude Code Settings"
            description="Open Claude Code settings in a new editor tab"/>

        <!-- Send current file path (and selected line range) to the Claude Code chat input -->
        <action
            id="ClaudeCode.SendSelection"
            class="com.github.yhk1038.claudecodegui.actions.SendSelectionToClaudeAction"
            text="Send to Claude Code"
            description="Send the current file path (and selected line range) to the Claude Code chat input">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="alt K"/>
        </action>
    </actions>
</idea-plugin>
