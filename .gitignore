# IDE & Editor
.idea/
.vscode/
.fleet/
*.iws
*.ipr
*.iml
ignore/

# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
local.properties

# IntelliJ
out/
.intellijPlatform/
.kotlin/

# Node.js / WebView
webview/node_modules/
webview/dist/
.vite/

# WebView build output
src/main/resources/webview/

# Node.js backend build output
backend/node_modules/
backend/dist/
src/main/resources/backend/

# Release artifacts (ccg tgz, runtime tgz)
/dist/

# TypeScript build info
*.tsbuildinfo

# TypeScript in-place compile artifacts
backend/src/**/*.js

# Vite config build artifacts
webview/vite.config.d.ts
webview/vite.config.js

# Test coverage & reports
webview/coverage/
webview/html/
backend/coverage/

# Claude Code / OMC
.claude.json
# .claude/ — whitelist policy: local by default; only shared contributor
# skills are tracked. Owner-only skills (deploy, precheck, release-monitor,
# cc-gui-reporter), personal settings/backups, and internal docs stay local.
.claude/*
!.claude/skills/
.claude/skills/*
!.claude/skills/pr-checklist/
!.claude/skills/add-locale/
.claude-code-gui/
.omc/
.taskmaster/

# OS
.DS_Store

# Environment (secrets)
# Ignore every real .env file — they hold build-injected keys.
# Only the committed .env.example template is tracked (see negation below).
.env
.env*
!.env.example

# Logs
*.log
npm-debug.log*

www/

# scripts/ — whitelist policy: everything under scripts/ is local by
# default; only the shared, non-owner developer tools below are tracked.
# Deploy/marketplace scripts (release.sh, marketplace-monitor.sh,
# verifier-allowlist.txt) are owner-only — like the .claude/ deploy
# skills — and intentionally stay local-only (not re-included here).
scripts/*
!scripts/build.sh
!scripts/zombies.sh
!scripts/all-build-run-ide.sh
!scripts/sync-announcement-core.sh
